<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>معايدة عيد الفطر</title>

<style>
    body {
        font-family: "Tajawal", sans-serif;
        background: #f7f3ef;
        text-align: center;
        padding: 20px;
    }

    .card {
        background: white;
        padding: 25px;
        border-radius: 15px;
        max-width: 420px;
        margin: auto;
        box-shadow: 0 0 10px #ddd;
    }

    input {
        width: 90%;
        padding: 12px;
        margin: 10px 0;
        border-radius: 8px;
        border: 1px solid #ccc;
        font-size: 18px;
    }

    button {
        background: #25D366;
        color: white;
        padding: 12px 20px;
        border: none;
        border-radius: 8px;
        font-size: 18px;
        cursor: pointer;
        width: 95%;
    }

    .eid-title {
        font-size: 32px;
        margin-top: 20px;
        color: #b88a44;
        font-weight: bold;
    }

    .text {
        font-size: 20px;
        margin-top: 15px;
        color: #444;
        line-height: 1.7;
    }
</style>

</head>
<body>

<div class="card">

    <h3>اكتب الاسم</h3>
    <input id="nameInput" type="text" placeholder="اكتب اسمك">

    <button onclick="share()">مشاركة واتساب</button>

    <h2 class="eid-title">عيد سعيد</h2>
    <h3>Eid Mubarak</h3>

    <p class="text">
        بمناسبة عيد الفطر أسأل الله أن يعيده عليكم بالصحة والخير والبركة
    </p>

</div>

<script>
function share() {
    let name = document.getElementById("nameInput").value;
    if (name.trim() === "") {
        alert("اكتب الاسم أولاً");
        return;
    }

    let message = `عيد سعيد يا ${name} 🌙✨\n\nبمناسبة عيد الفطر أسأل الله أن يعيده عليكم بالصحة والخير والبركة`;
    let url = "https://wa.me/?text=" + encodeURIComponent(message);
    window.open(url, "_blank");
}
</script>

</body>
</html>
